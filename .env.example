# JanApp environment variables — kopieer naar .env voor lokaal gebruik.
# In productie (Dokploy) worden deze als Environment Variables ingesteld.

# Finnhub API key — nog uitsluitend voor watchlist-NIEUWS (fase 3a).
# Koersen lopen sinds fase 5 niet meer via Finnhub: het gratis plan heeft geen
# historische candles (deltas moesten zich maandenlang opsparen) en is US-only.
# Gratis key via https://finnhub.io/register
FINNHUB_API_KEY=

# Koersen (fase 5) — US-aandelen & ETF's + de EUR/RUB-wisselkoers.
# Gratis key via https://twelvedata.com  (8 credits/min, 800/dag)
TWELVEDATA_API_KEY=

# Koersen (fase 5) — Euronext Amsterdam (.AS), Warschau (.WA) e.d.
# Moet server-side: EODHD stuurt geen CORS-header, dus de browser mag 'm niet
# rechtstreeks aanroepen. Gratis key via https://eodhd.com (20 calls/dag).
EODHD_API_KEY=

# Raw URL van feed.json uit de janapp-feed pipeline (fase 3a).
# Leeg laten totdat de pipeline draait; app toont dan lege-staat.
FEED_URL=

# Sparrente/hypotheekrente (fase 12, vervroegd): geen key nodig — rates.js
# scrapet actuelerentestanden.nl (best-effort, ververst 1x/dag). Zie rates.js
# voor de aanpak en waarom dit fragieler is dan de koersen-API's.

# Optioneel: pad voor SQLite-db en uploads. Docker: /data. Lokaal: ./data.
# DATA_DIR=./data

# Optioneel: server-poort. Default 3000, in Docker via compose.
# PORT=3000
